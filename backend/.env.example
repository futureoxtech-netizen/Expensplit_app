# Mongo / Redis
MONGO_URI=mongodb+srv://moiz031188_db_user:dSeNb3vGv5jUr8hR@cluster0.wg1bkyb.mongodb.net/?appName=Cluster0
# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

# Google OAuth — comma-separated list of EVERY accepted ID-token audience.
# Each platform mints tokens with a different audience (web/Android client vs
# the separate iOS client), so list them all or that platform's login fails
# with "invalid token". GOOGLE_CLIENT_IDS takes precedence; GOOGLE_CLIENT_ID
# is kept as a single-value fallback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_IDS=

# Optional integrations (leave blank to use stubs)
OCR_PROVIDER_KEY=
AI_CATEGORIZATION_KEY=
FCM_SERVER_KEY=
FX_API_KEY=

# OneSignal push notifications (leave blank to disable push — sockets still work)
